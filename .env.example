# ======================================
# Kulto3D — Environment Variables Example
# ======================================
# Copy this file to .env.local for development
# or set these in the VPS for production.

# --- Supabase (proyecto dedicado a Kulto3D) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=         # NUNCA con prefix NEXT_PUBLIC

# --- Sitio ---
NEXT_PUBLIC_SITE_URL=https://kulto3d.com

# --- MercadoPago (Argentina) ---
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# --- Contacto / Social ---
NEXT_PUBLIC_WHATSAPP_NUMBER=54911XXXXXXXX
NEXT_PUBLIC_INSTAGRAM_HANDLE=kulto3d

# --- Analytics ---
# Google Analytics 4 Measurement ID (formato: G-XXXXXXXXXX)
# Crear en https://analytics.google.com/analytics/web/
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- AI (opcional, para generación de copy automática) ---
ANTHROPIC_API_KEY=                  # solo server, NUNCA con prefix NEXT_PUBLIC
